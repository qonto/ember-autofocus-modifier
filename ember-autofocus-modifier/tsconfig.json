{
  "extends": "@ember/library-tsconfig/tsconfig.json",
  "include": ["src/**/*", "unpublished-development-types/**/*"],
  "glint": {
    "environment": "ember-loose"
  },
  "compilerOptions": {
    "allowJs": false,
    "rootDir": "src",
    "declarationDir": "declarations",
    "skipLibCheck": true
  }
}
