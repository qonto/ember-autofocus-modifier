{
  "name": "test-app",
  "version": "7.0.1",
  "private": true,
  "description": "Test app for ember-autofocus-modifier addon",
  "repository": "",
  "license": "MIT",
  "author": "",
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  },
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "ember build --environment=production",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\"",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\"",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "glint",
    "start": "vite",
    "test": "concurrently \"pnpm:lint\" \"pnpm:test:*\" --names \"lint,test:\"",
    "test:ember": "vite build --mode development && ember test --path dist"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-runtime": "^7.29.7",
    "@babel/preset-typescript": "^8.0.1",
    "@babel/runtime": "^8.0.0",
    "@ember/optional-features": "3.0.0",
    "@ember/string": "4.0.1",
    "@ember/test-helpers": "5.4.3",
    "@embroider/macros": "1.20.5",
    "@glimmer/component": "^2.1.1",
    "@glimmer/tracking": "^1.1.2",
    "@glint/core": "^1.5.2",
    "@glint/environment-ember-loose": "^1.5.2",
    "@glint/template": "^1.7.8",
    "@types/ember__component": "^4.0.22",
    "@types/ember__object": "^4.0.12",
    "@types/htmlbars-inline-precompile": "^3.0.4",
    "@types/qunit": "^2.19.14",
    "broccoli-asset-rev": "3.0.0",
    "concurrently": "10.0.3",
    "decorator-transforms": "^2.4.0",
    "ember-auto-import": "2.13.1",
    "ember-cli": "7.1.0",
    "ember-cli-app-version": "7.0.0",
    "ember-cli-babel": "8.3.1",
    "ember-cli-dependency-checker": "3.3.3",
    "ember-cli-htmlbars": "7.0.1",
    "ember-cli-inject-live-reload": "2.1.0",
    "ember-cli-sri": "2.1.1",
    "ember-cli-terser": "4.0.2",
    "ember-cli-typescript": "^5.3.0",
    "ember-disable-prototype-extensions": "^1.1.3",
    "ember-fetch": "8.1.2",
    "ember-load-initializers": "3.0.1",
    "ember-page-title": "9.0.3",
    "ember-qunit": "9.1.0",
    "ember-resolver": "13.2.0",
    "ember-source": "7.1.0",
    "ember-source-channel-url": "3.0.0",
    "ember-template-lint": "7.9.3",
    "ember-try": "4.0.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-ember": "13.4.1",
    "eslint-plugin-n": "18.2.1",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-qunit": "8.2.6",
    "globals": "^17.7.0",
    "lerna-changelog": "2.2.0",
    "loader.js": "4.7.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.9.4",
    "qunit": "2.26.0",
    "qunit-dom": "3.5.1",
    "release-it": "19.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.62.1",
    "@ember/app-tsconfig": "^2.0.0",
